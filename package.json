{
  "name": "mcp-mat",
  "version": "0.1.0",
  "description": "Headless Eclipse MAT MCP server",
  "mcpName": "io.github.codelipenghui/mcp-mat",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/src/server.js",
  "bin": {
    "mcp-mat": "dist/src/server.js"
  },
  "files": [
    "dist/src"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/codelipenghui/mcp-mat.git"
  },
  "keywords": [
    "mcp",
    "eclipse-mat",
    "heap-dump",
    "memory-analysis",
    "java"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/server.ts",
    "start": "node dist/src/server.js",
    "test": "tsx --test test/**/*.test.ts",
    "prepublishOnly": "npm run build && node scripts/prepublish.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
